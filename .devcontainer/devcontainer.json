{
  "name": "Router-Daemon",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "privileged": true,
  "runArgs": [
    "--privileged",
    "--restart=unless-stopped"
  ],
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools"
      ]
    }
  },
  "forwardPorts": []
}
